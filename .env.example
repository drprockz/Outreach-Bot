# ── OUTREACH IDENTITY ──────────────────────────────────────
OUTREACH_DOMAIN=trysimpleinc.com

# ── INBOXES (GWS app passwords — 2FA must be on) ───────────
INBOX_1_USER=darshan@trysimpleinc.com
INBOX_1_PASS=xxxx xxxx xxxx xxxx
INBOX_2_USER=hello@trysimpleinc.com
INBOX_2_PASS=xxxx xxxx xxxx xxxx

# ── SMTP ────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── IMAP ────────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

# ── SEND LIMITS ─────────────────────────────────────────────
DAILY_SEND_LIMIT=0
MAX_PER_INBOX=17
SEND_DELAY_MIN_MS=180000
SEND_DELAY_MAX_MS=420000
SEND_WINDOW_START_IST=9
SEND_WINDOW_END_IST=17

# ── AI MODELS ───────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

ANTHROPIC_API_KEY=
MODEL_HOOK=claude-sonnet-4-20250514
MODEL_BODY=claude-haiku-4-5-20251001
MODEL_CLASSIFY=claude-haiku-4-5-20251001

# ── EMAIL VERIFICATION ──────────────────────────────────────
MEV_API_KEY=

# ── ALERTS ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── SAFETY THRESHOLDS ───────────────────────────────────────
BOUNCE_RATE_HARD_STOP=0.02
SPAM_RATE_HARD_STOP=0.001
CLAUDE_DAILY_SPEND_CAP=3.00
MAX_EMAIL_WORDS=90
MIN_EMAIL_WORDS=40
DISABLE_OPEN_TRACKING=true
DISABLE_CLICK_TRACKING=true
HTML_EMAIL=false

# ── CONTENT SPAM WORD BLOCKLIST ─────────────────────────────
SPAM_WORDS=free,guarantee,guaranteed,100%,winner,prize,congratulations,limited time,act now,click here,buy now,discount,offer,deal,no obligation,risk-free,earn money,make money,income,revenue,ROI,results,increase sales

# ── DATABASE ────────────────────────────────────────────────
DATABASE_URL="postgresql://radar:CHANGE_ME@127.0.0.1:5432/radar?schema=public"
DATABASE_URL_TEST="postgresql://radar:CHANGE_ME@127.0.0.1:5432/radar_test?schema=public"

# ── DASHBOARD ───────────────────────────────────────────────
DASHBOARD_PORT=3001
DASHBOARD_URL=https://radar.simpleinc.cloud
DASHBOARD_PASSWORD=your_strong_password_here
JWT_SECRET=your_random_64char_secret_here
JWT_EXPIRES_IN=7d

# ── LEADS COCKPIT ────────────────────────────────────────
# Gate for the bulk-retry endpoint (POST /api/leads/bulk/retry). When unset
# or false, the endpoint returns 503 — dry-run cost previews still work.
# Flip to "true" only after you've smoke-tested costs against the dryRun
# response, since each retry can spend real money on Claude/Gemini.
BULK_RETRY_ENABLED=false
# Per-call cost for the MEV email-verify API. Used by the bulk-retry dryRun
# cost estimator when no recent samples exist. Falls back to 0.0006 USD.
MEV_COST_PER_CALL=0.0006

# ── SIGNAL AGGREGATOR (Move #1) ───────────────────────────
SIGNALS_ENABLED=false
SIGNALS_GLOBAL_TIMEOUT_MS=20000
SIGNALS_ADAPTERS_ENABLED=google_news,company_blog,indian_press,tech_stack,cert_transparency,pagespeed,careers_page,product_hunt,github,corp_filings

# ── REDIS ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── GOOGLE OAUTH ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://radar.simpleinc.cloud/auth/google/callback

# ── RAZORPAY ───────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
