{
  "name": "radar",
  "version": "2.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:db:reset": "DATABASE_URL=\"$DATABASE_URL_TEST\" prisma migrate reset --force --skip-seed",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "test:api": "npm run test --workspace=apps/api",
    "build": "npm run build:shared && npm run build:api && npm run build:web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:shared": "npm run build --workspace=packages/shared"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^6.19.3",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "imapflow": "^1.0.169",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.9.4",
    "node-cron": "^3.0.3",
    "node-telegram-bot-api": "^0.66.0",
    "nodemailer": "^6.9.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "prisma": "^6.19.3",
    "vitest": "^1.6.0"
  }
}
